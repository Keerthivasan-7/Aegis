{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in the assessment system, either a student/candidate or admin/examiner.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Firebase Authentication UID." },
        "name": { "type": "string", "minLength": 2, "maxLength": 100, "description": "Display name of the user." },
        "email": { "type": "string", "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$", "description": "Email address of the user." },
        "role": { "type": "string", "enum": ["student", "admin"], "description": "The system role of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time this user profile was created." }
      },
      "required": ["userId", "name", "email", "role", "createdAt"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "Represents an assessment definition containing a list of questions, created by an examiner.",
      "type": "object",
      "properties": {
        "assessmentId": { "type": "string" },
        "title": { "type": "string", "minLength": 3, "maxLength": 150 },
        "description": { "type": "string", "maxLength": 2000 },
        "timeLimit": { "type": "integer", "description": "Time limit in minutes." },
        "questions": { "type": "array", "description": "Array of question objects." },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assessmentId", "title", "timeLimit", "questions", "createdBy", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Represents a student's submission for an assessment, including their answers and proctoring/grading results.",
      "type": "object",
      "properties": {
        "submissionId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "answers": { "type": "object", "description": "Map of answers." },
        "status": { "type": "string", "enum": ["ongoing", "submitted", "graded"] },
        "score": { "type": "number" },
        "totalPoints": { "type": "number" },
        "proctoringLogs": { "type": "array", "description": "Proctoring violation logs." },
        "aiRiskScore": { "type": "number", "description": "Risk score evaluated by AI (0 to 100)." },
        "aiProctoringSummary": { "type": "string", "maxLength": 3000 },
        "startedAt": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["submissionId", "assessmentId", "studentId", "studentName", "status", "startedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles catalogued by UID."
    },
    "assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Assessments catalogued by assessmentId."
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Submission/Results of assessments catalogued by submissionId."
    }
  }
}
