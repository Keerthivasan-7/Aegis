rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for validation
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.role == 'student'; // Prevent self-promoting on signup
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));
      allow delete: if isAdmin();
    }

    // --- ASSESSMENTS COLLECTION ---
    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- SUBMISSIONS COLLECTION ---
    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid 
                     && request.resource.data.status == 'ongoing'
                     && request.resource.data.keys().hasAll(['submissionId', 'assessmentId', 'studentId', 'status', 'answers', 'proctoringLogs', 'startedAt']);
                     
      allow update: if isSignedIn() && (
        isAdmin() || (
          // Candidate updating their ongoing assessment answers and logging proctoring events
          resource.data.studentId == request.auth.uid 
          && resource.data.status == 'ongoing'
          && request.resource.data.status in ['ongoing', 'submitted']
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'totalPoints', 'aiRiskScore', 'aiProctoringSummary', 'studentId', 'assessmentId'])
        )
      );
      allow delete: if isAdmin();
    }
  }
}
